#!/usr/bin/env bash
# Dev shortcut: `./run <rom.nes> [more-args]`
#
# Rebuilds the release binary (no-op if up to date - seconds when cached)
# and execs it with all forwarded args. Bash tab-completion on the ROM
# path works via default filename completion - cargo's own completion
# doesn't cover positional args to the user binary.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"
cargo build --release --bin vibenes --quiet
exec ./target/release/vibenes "$@"
